# Groww Review Pulse — environment variables

# MCP profile: local (mock stdio servers) | remote (Saksham HTTP MCP server)
MCP_PROFILE=local

# Remote Saksham MCP server (https://github.com/tejas2904-RM/MCP)
# MCP_DOCS_SERVER_URL=https://saksham-mcp-server-i1js.onrender.com

# Google Doc ID for remote append_to_doc (create a doc, copy ID from URL)
# GOOGLE_DOC_ID=

# Gmail draft recipient for remote create_email_draft (your email or alias)
# GMAIL_RECIPIENT=you@example.com

# GitHub Actions secrets (for scheduled weekly run — see .github/workflows/weekly-pulse.yml)
# GROQ_API_KEY, GOOGLE_DOC_ID, GMAIL_RECIPIENT, MCP_PROFILE=remote
# RENDER_API_URL, API_KEY (sync artifacts to Phase 9 backend after weekly run)

# Phase 9 API (Render backend)
# API_DATA_DIR=data/api
# CORS_ORIGINS=http://localhost:3000,https://groww-pulse.vercel.app
# API_KEY=
# API_HOST=0.0.0.0
# API_PORT=8000

# Optional override for MCP config file path
# MCP_CONFIG_PATH=config/mcp_servers.local.json

# Sample review data directory
# SAMPLE_DATA_DIR=data/sample

# Recency window for Phase 1 ingestion (8–12 weeks, default 10)
# RECENCY_WEEKS=10

# Google OAuth — required when MCP_PROFILE=remote
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# LLM (Phase 3+) — Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
